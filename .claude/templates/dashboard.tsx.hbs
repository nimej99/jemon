'use client';

import { useState, useCallback } from 'react';
import { CampusScene } from '@jemon/ui/scenes';
import type { BuildingData } from '@jemon/ui/scenes';

// ── static seed data ─────────────────────────────────────────────────────────
// Replace with live data from useMetricStream() or SWR when available.

const SEED_BUILDINGS: BuildingData[] = {{{buildings}}};

// ── component ────────────────────────────────────────────────────────────────

export function {{componentName}}() {
  const [ready, setReady] = useState(false);

  const handleReady = useCallback(() => {
    setReady(true);
  }, []);

  return (
    <section
      aria-label="Campus infrastructure overview"
      style={{
        position: 'relative',
        display: 'inline-block',
        background: '#0a0e1a',
        borderRadius: 8,
        overflow: 'hidden',
        border: '1px solid #1e293b',
      }}
    >
      {!ready && (
        <div
          style={{
            position: 'absolute',
            inset: 0,
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            color: '#475569',
            fontFamily: 'ui-monospace, monospace',
            fontSize: 12,
          }}
        >
          Initialising scene…
        </div>
      )}

      <CampusScene
        width={ {{{width}}} }
        height={ {{{height}}} }
        buildings={SEED_BUILDINGS}
        onReady={handleReady}
      />
    </section>
  );
}
